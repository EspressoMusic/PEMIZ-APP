# Copy to keystore.properties (never commit the real file).
# Generate keystore:
#   keytool -genkey -v -keystore linky-release.keystore -alias linky -keyalg RSA -keysize 2048 -validity 10000
storeFile=linky-release.keystore
storePassword=your-store-password
keyAlias=linky
keyPassword=your-key-password
