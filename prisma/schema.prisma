generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel + Supabase integration fills POSTGRES_* automatically
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model PlatformConfig {
  id                       String   @id @default("default")
  signupsEnabled           Boolean  @default(true)
  trialClosureEnabled      Boolean  @default(true)
  trialWarningEmailsEnabled Boolean @default(true)
  updatedAt                DateTime @updatedAt
}

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  passwordHash               String
  name                       String
  phone                      String?
  phoneVerified              Boolean   @default(false)
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  passwordResetToken         String?   @unique
  passwordResetExpiresAt     DateTime?
  role                       String    @default("OWNER")
  createdAt                  DateTime  @default(now())
  business                   Business?
  otpCodes                   OtpCode[]
  pushSubscriptions          SellerPushSubscription[]
}

model SellerPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PublicPhoneOtp {
  id         String   @id @default(cuid())
  businessId String
  phone      String
  code       String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([businessId, phone])
}

model RateLimitBucket {
  key     String   @id
  count   Int
  resetAt DateTime
}

model Business {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  type            String
  storeTheme             String   @default("calm")
  storeLocale            String   @default("he")
  storePolicy            String?
  storeTerms             String?
  storeBroadcast         String?
  storeBroadcastAt       DateTime?
  storeBroadcastHistory  String?
  orderScheduleEnabled   Boolean  @default(false)
  orderSchedule          String?
  appointmentSlotGapMinutes      Int    @default(15)
  appointmentSlotDurationMinutes Int    @default(60)
  appointmentBookingStart        String  @default("09:00")
  appointmentBookingEnd          String  @default("18:00")
  appointmentBookingByDay        Boolean @default(false)
  sellerAlertsEnabled    Boolean  @default(false)
  sellerAlertOnInquiry   Boolean  @default(true)
  sellerAlertOnChat      Boolean  @default(true)
  sellerAlertOnNewOrder  Boolean  @default(true)
  sellerAlertOnLowStock  Boolean  @default(true)
  // JSON: which customer-store panels are visible (see store-panels-visible.ts).
  storePanelsVisible     String?
  isActive               Boolean  @default(false)
  approvedAt      DateTime?
  subscriptionActiveAt   DateTime?
  subscriptionPlan       String?
  trialWarned7dAt        DateTime?
  trialWarned3dAt        DateTime?
  trialWarned1dAt        DateTime?
  ownerId         String   @unique
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  termsAcceptedAt DateTime?
  createdAt       DateTime @default(now())
  products        Product[]
  storeDeals      StoreDeal[]
  orders          Order[]
  slots           AppointmentSlot[]
  appointments    Appointment[]
  inquiries       Inquiry[]
  chatMessages    StoreChatMessage[]
  faqItems        FaqItem[]
}

model FaqItem {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  question   String
  answer     String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([businessId, sortOrder])
}

model Product {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  price       Float
  salePrice   Float?
  stock                  Int?
  serviceDurationMinutes Int?
  isActive               Boolean     @default(true)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
  dealsAsA    StoreDeal[]       @relation("DealProductA")
  dealsAsB    StoreDeal[]       @relation("DealProductB")
  dealItems   StoreDealItem[]   @relation("DealLineProducts")

  @@index([businessId])
}

model StoreDeal {
  id          String            @id @default(cuid())
  businessId  String
  business    Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  imageUrl    String?
  productAId  String?
  productBId  String?
  productA    Product?          @relation("DealProductA", fields: [productAId], references: [id])
  productB    Product?          @relation("DealProductB", fields: [productBId], references: [id])
  dealPrice                  Float
  validUntil                 DateTime
  // 1 = once per customer; 0 = unlimited; N = up to N redemptions
  maxRedemptionsPerCustomer  Int               @default(1)
  isActive                   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  redemptions DealRedemption[]
  items       StoreDealItem[]

  @@index([businessId])
}

model StoreDealItem {
  id        String    @id @default(cuid())
  dealId    String
  deal      StoreDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation("DealLineProducts", fields: [productId], references: [id])
  quantity  Int       @default(1)
  sortOrder Int       @default(0)

  @@unique([dealId, productId])
  @@index([dealId])
}

model DealRedemption {
  id            String    @id @default(cuid())
  dealId        String
  deal          StoreDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customerPhone String
  createdAt     DateTime  @default(now())

  @@index([dealId, customerPhone])
}

model Order {
  id            String      @id @default(cuid())
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())
  items         OrderItem[]

  @@index([businessId])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
}

model AppointmentSlot {
  id           String        @id @default(cuid())
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  startAt      DateTime
  endAt        DateTime
  maxBookings  Int           @default(1)
  createdAt    DateTime      @default(now())
  appointments Appointment[]

  @@index([businessId, startAt])
}

model Appointment {
  id            String          @id @default(cuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  slotId        String
  slot          AppointmentSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  notes           String?
  status          String          @default("CONFIRMED")
  sellerHiddenAt  DateTime?
  createdAt       DateTime        @default(now())

  @@index([businessId])
  @@index([slotId])
}

model Inquiry {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String?
  customerEmail String?
  subject       String   @default("")
  message       String
  sellerReply   String?
  sellerReplyAt DateTime?
  createdAt     DateTime @default(now())

  @@index([businessId])
}

model StoreChatMessage {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  channel       String
  customerPhone String?
  customerName  String
  authorRole    String
  body          String
  replyToId     String?
  replyTo       StoreChatMessage?  @relation("ChatMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       StoreChatMessage[] @relation("ChatMessageReplies")
  likes         StoreChatMessageLike[]
  createdAt     DateTime @default(now())

  @@index([businessId, channel, createdAt])
  @@index([businessId, channel, customerPhone])
  @@index([replyToId])
}

model StoreChatMessageLike {
  id            String           @id @default(cuid())
  messageId     String
  message       StoreChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  customerPhone String
  createdAt     DateTime         @default(now())

  @@unique([messageId, customerPhone])
  @@index([messageId])
}
