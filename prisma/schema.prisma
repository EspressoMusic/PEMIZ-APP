generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel + Supabase integration fills POSTGRES_* automatically
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model PlatformConfig {
  id                        String   @id @default("default")
  signupsEnabled            Boolean  @default(true)
  trialClosureEnabled       Boolean  @default(true)
  trialWarningEmailsEnabled Boolean  @default(true)
  maxAppointmentsPerBusiness Int     @default(100)
  maxOrderItemsPerOrder      Int     @default(200)
  updatedAt                 DateTime @updatedAt
}

model DemoBooking {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String?
  notes         String?
  locale        String   @default("en")
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  passwordHash               String
  name                       String
  phone                      String?
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?   @unique
  emailVerificationExpiresAt DateTime?
  passwordResetToken         String?   @unique
  passwordResetExpiresAt     DateTime?
  role                       String    @default("OWNER")
  createdAt                  DateTime  @default(now())
  business                   Business?
  pushSubscriptions          SellerPushSubscription[]
}

model SellerPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model CustomerPushSubscription {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model AppointmentWaitlistSubscription {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  endpoint      String   @unique
  customerPhone String
  createdAt     DateTime @default(now())

  @@index([businessId])
}

model RateLimitBucket {
  key     String   @id
  count   Int
  resetAt DateTime
}

model Business {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  type            String
  storeTheme             String   @default("calm")
  storeDecoration        String   @default("none")
  storeLocale            String   @default("en")
  storePolicy            String?
  storeTerms             String?
  storeOpeningHours      String?
  storeAddress           String?
  storeBroadcast         String?
  storeBroadcastAt       DateTime?
  storeBroadcastHistory  String?
  platformOwnerMessage       String?
  platformOwnerMessageAt     DateTime?
  platformOwnerMessageReadAt DateTime?
  orderScheduleEnabled   Boolean  @default(false)
  orderSchedule          String?
  // If true (default), new orders start PENDING and need the seller to confirm them.
  // If false, new orders are created already CONFIRMED (no manual approval step).
  orderConfirmationRequired Boolean @default(true)
  appointmentSlotGapMinutes      Int    @default(0)
  appointmentSlotDurationMinutes Int    @default(60)
  appointmentBookingStart        String  @default("09:00")
  appointmentBookingEnd          String  @default("18:00")
  appointmentBookingByDay        Boolean @default(false)
  sellerAlertsEnabled    Boolean  @default(false)
  sellerAlertOnInquiry   Boolean  @default(true)
  sellerAlertOnChat      Boolean  @default(true)
  sellerAlertOnNewOrder  Boolean  @default(true)
  sellerAlertOnLowStock  Boolean  @default(true)
  // JSON: which customer-store panels are visible (see store-panels-visible.ts).
  storePanelsVisible     String?
  isActive               Boolean  @default(false)
  approvedAt      DateTime?
  subscriptionActiveAt   DateTime?
  subscriptionPlan       String?
  // paddle | stripe — which provider bills this store
  subscriptionBillingProvider            String?
  subscriptionExternalCustomerId         String?
  subscriptionExternalSubscriptionId     String?
  // Legacy Stripe IDs (kept for existing rows)
  subscriptionStripeCustomerId     String?
  subscriptionStripeSubscriptionId String?
  subscriptionCurrentPeriodStart   DateTime?
  subscriptionCurrentPeriodEnd     DateTime?
  trialWarned7dAt        DateTime?
  trialWarned3dAt        DateTime?
  trialWarned1dAt        DateTime?
  ownerId         String   @unique
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  termsAcceptedAt DateTime?
  nextOrderNumber Int      @default(1)
  createdAt       DateTime @default(now())
  products        Product[]
  storeDeals      StoreDeal[]
  orders          Order[]
  slots           AppointmentSlot[]
  appointments    Appointment[]
  inquiries       Inquiry[]
  chatMessages    StoreChatMessage[]
  faqItems        FaqItem[]
  customerPushSubscriptions CustomerPushSubscription[]
  appointmentWaitlistSubscriptions AppointmentWaitlistSubscription[]
  reviews         StoreReview[]
  coupons         Coupon[]
}

model StoreReview {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  rating        Int
  comment       String?
  sellerReply   String?
  sellerReplyAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([businessId, createdAt])
}

model FaqItem {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  question   String
  answer     String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([businessId, sortOrder])
}

model Product {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  imageUrls   String[]    @default([])
  price       Float
  salePrice   Float?
  stock                  Int?
  serviceDurationMinutes Int?
  isActive               Boolean     @default(true)
  // Soft-delete: set instead of removing the row when order history still
  // references this product, so past orders keep showing its name/price.
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
  dealsAsA    StoreDeal[]       @relation("DealProductA")
  dealsAsB    StoreDeal[]       @relation("DealProductB")
  dealItems   StoreDealItem[]   @relation("DealLineProducts")

  @@index([businessId])
}

model StoreDeal {
  id          String            @id @default(cuid())
  businessId  String
  business    Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  imageUrl    String?
  productAId  String?
  productBId  String?
  productA    Product?          @relation("DealProductA", fields: [productAId], references: [id])
  productB    Product?          @relation("DealProductB", fields: [productBId], references: [id])
  dealPrice                  Float
  validUntil                 DateTime
  // 1 = once per customer; 0 = unlimited; N = up to N redemptions
  maxRedemptionsPerCustomer  Int               @default(1)
  isActive                   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  redemptions DealRedemption[]
  items       StoreDealItem[]

  @@index([businessId])
}

model StoreDealItem {
  id        String    @id @default(cuid())
  dealId    String
  deal      StoreDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation("DealLineProducts", fields: [productId], references: [id])
  quantity  Int       @default(1)
  sortOrder Int       @default(0)

  @@unique([dealId, productId])
  @@index([dealId])
}

model DealRedemption {
  id            String    @id @default(cuid())
  dealId        String
  deal          StoreDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  customerPhone String
  createdAt     DateTime  @default(now())

  @@index([dealId, customerPhone])
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id                        String              @id @default(cuid())
  businessId                String
  business                  Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code                      String
  discountType              CouponDiscountType
  discountValue             Float
  minOrderAmount            Float?
  // null = unlimited total redemptions
  maxRedemptions            Int?
  // 1 = once per customer; 0 = unlimited; N = up to N redemptions
  maxRedemptionsPerCustomer Int                 @default(1)
  isActive                  Boolean             @default(true)
  // If true, this coupon's code is handed to a customer automatically after they submit a store review.
  // Only one coupon per business may have this set (enforced in the API layer).
  autoGrantOnReview         Boolean             @default(false)
  validUntil                DateTime?
  createdAt                 DateTime            @default(now())
  redemptions               CouponRedemption[]
  orders                    Order[]

  @@unique([businessId, code])
  @@index([businessId])
}

model CouponRedemption {
  id            String   @id @default(cuid())
  couponId      String
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  customerPhone String
  orderId       String
  createdAt     DateTime @default(now())

  @@index([couponId, customerPhone])
}

model Order {
  id             String      @id @default(cuid())
  businessId     String
  business       Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderNumber    Int
  customerName   String
  customerPhone  String
  customerEmail  String?
  customerAddress        String?
  customerAddressLat     Float?
  customerAddressLng     Float?
  customerAddressPlaceId String?
  notes          String?
  status         String      @default("PENDING")
  couponId       String?
  coupon         Coupon?     @relation(fields: [couponId], references: [id])
  couponCode     String?
  discountAmount Float       @default(0)
  sellerHiddenAt DateTime?
  createdAt      DateTime    @default(now())
  items          OrderItem[]
  pushSubscriptions OrderPushSubscription[]

  @@unique([businessId, orderNumber])
  @@index([businessId])
}

model OrderPushSubscription {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([orderId, endpoint])
  @@index([orderId])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Float
}

model AppointmentSlot {
  id           String        @id @default(cuid())
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  startAt      DateTime
  endAt        DateTime
  maxBookings  Int           @default(1)
  createdAt    DateTime      @default(now())
  appointments Appointment[]

  @@index([businessId, startAt])
}

model Appointment {
  id            String          @id @default(cuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  slotId        String
  slot          AppointmentSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String
  notes           String?
  status          String          @default("CONFIRMED")
  sellerHiddenAt  DateTime?
  createdAt       DateTime        @default(now())

  @@index([businessId])
  @@index([slotId])
}

model Inquiry {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName  String
  customerPhone String?
  customerEmail String?
  subject       String   @default("")
  message       String
  sellerReply          String?
  sellerReplyAt        DateTime?
  customerResolution   String?
  customerResolutionAt DateTime?
  createdAt            DateTime @default(now())

  @@index([businessId])
}

model StoreChatMessage {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  channel       String
  customerPhone String?
  customerName  String
  authorRole    String
  body          String
  replyToId     String?
  replyTo       StoreChatMessage?  @relation("ChatMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       StoreChatMessage[] @relation("ChatMessageReplies")
  likes                StoreChatMessageLike[]
  customerResolution   String?
  customerResolutionAt DateTime?
  createdAt            DateTime @default(now())

  @@index([businessId, channel, createdAt])
  @@index([businessId, channel, customerPhone])
  @@index([replyToId])
}

model StoreChatMessageLike {
  id            String           @id @default(cuid())
  messageId     String
  message       StoreChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  customerPhone String
  createdAt     DateTime         @default(now())

  @@unique([messageId, customerPhone])
  @@index([messageId])
}
