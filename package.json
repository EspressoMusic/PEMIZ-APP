{
  "name": "linky",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:vercel": "npx vercel env run -- next dev",
    "build": "prisma migrate deploy && prisma generate && next build",
    "db:migrate": "prisma migrate deploy",
    "migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "start": "next start",
    "lint": "eslint",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "vapid:generate": "node scripts/generate-vapid-keys.mjs",
    "mobile:install": "npm install --prefix mobile",
    "mobile:sync": "npm run --prefix mobile cap:sync",
    "mobile:prepare:play": "node mobile/scripts/prepare-play-release.mjs",
    "mobile:android": "npm run --prefix mobile cap:open:android",
    "mobile:bundle": "cd mobile/android && gradlew.bat bundleRelease",
    "mobile:apk": "cd mobile/android && gradlew.bat assembleDebug",
    "mobile:ios": "npm run --prefix mobile cap:open:ios"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/preferences": "^7.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "stripe": "^22.2.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
