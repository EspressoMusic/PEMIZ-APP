# Supabase → Project Settings → Database → Connection string
#
# 1) POSTGRES_PRISMA_URL = "Transaction" pooler, port 6543, add ?pgbouncer=true
#    Host looks like: aws-1-....pooler.supabase.com:6543
#
# 2) POSTGRES_URL_NON_POOLING = "Direct connection", port 5432
#    Host looks like: db.xxxxxxxxx.supabase.co:5432  (NOT pooler.supabase.com)
#    Migrations (prisma migrate deploy) need this direct host.

POSTGRES_PRISMA_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-....pooler.supabase.com:6543/postgres?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

SESSION_SECRET="change-me-at-least-32-characters-long"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
# Capacitor native shell (mobile/) — loads the live site in a WebView (full sync with web).
# Production Play build: npm run mobile:prepare:play  (uses this URL)
# CAPACITOR_SERVER_URL="https://your-app.vercel.app"
# Native app opens here instead of the marketing homepage (seller login → dashboard when signed in).
# CAPACITOR_ENTRY_PATH="/app"
# NEXT_PUBLIC_CAPACITOR_ENTRY_PATH="/app"
# Marketing site — WhatsApp sales / support (Israeli mobile, e.g. 0586122187)
# NEXT_PUBLIC_MARKETING_WHATSAPP="0586122187"
# Local Android emulator: CAPACITOR_SERVER_URL="http://10.0.2.2:3000"
# Local device on same Wi‑Fi: CAPACITOR_SERVER_URL="http://192.168.x.x:3000"
# Secret path for design preview + platform console (no links in the UI).
# Generate a random 16–32 char segment (letters, numbers, _ -). Example shape only:
# STUDIO_ACCESS_PATH="your-random-segment-here"
# Password for /master (developer panel). Change in Vercel → Settings → Environment Variables, then redeploy.
MASTER_KEY="your-strong-password-here"
# Daily cron for trial-ending emails/push (Vercel Cron sends Authorization: Bearer …)
# CRON_SECRET="generate-a-long-random-string"
ADMIN_EMAIL="admin@linky.local"
# Shown to users when the app hits a server/DB error (email, phone, or WhatsApp).
# PLATFORM_SUPPORT_CONTACT="your@email.com"

# Web Push (seller alerts) — run: npm run vapid:generate
# VAPID_PUBLIC_KEY=""
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:admin@yourdomain.com"

# Subscription billing (off by default until a provider is configured)
# SUBSCRIPTION_PAYMENTS_ENABLED="true"
# SUBSCRIPTION_BILLING_PROVIDER="paddle"   # paddle (default) | stripe

# Paddle Billing (recommended for Israel — Merchant of Record)
# PADDLE_ENVIRONMENT="sandbox"             # sandbox | production
# PADDLE_API_KEY=""
# PADDLE_WEBHOOK_SECRET=""
# PADDLE_PRICE_PREMIUM="pri_..."           # $49 / month — up to 500 orders
# PADDLE_PRICE_ULTIMATE="pri_..."          # $89 / month — up to 1,000 orders

# Stripe (optional — switch SUBSCRIPTION_BILLING_PROVIDER to stripe)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PREMIUM="price_..."
# STRIPE_PRICE_ULTIMATE="price_..."

# RESEND_API_KEY=""
# EMAIL_FROM="Linky <noreply@yourdomain.com>"

# Product images — Supabase Storage bucket "product-images" (public read).
# Use the same Supabase project as POSTGRES_* (Project Settings → API).
# Run once if buckets are missing: node scripts/setup-storage-buckets.mjs
# SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=""  # service_role / secret key (server only)
# SUPABASE_SECRET_KEY=""        # optional alias (new Supabase keys)
# SUPABASE_PRODUCT_IMAGE_BUCKET="product-images"

