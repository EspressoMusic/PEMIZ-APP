# Supabase → Database → Connect (או Vercel Integration ממלא אוטומטית)
# Pooler 6543 + ?pgbouncer=true | Direct 5432
POSTGRES_PRISMA_URL="postgresql://postgres.[REF]:[PASSWORD]@....pooler.supabase.com:6543/postgres?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://postgres.[REF]:[PASSWORD]@....pooler.supabase.com:5432/postgres"

SESSION_SECRET="change-me-at-least-32-characters-long"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
MASTER_KEY="your-master-key"
ADMIN_EMAIL="admin@linky.local"

# Optional — real email in production
# RESEND_API_KEY=""
# EMAIL_FROM="Linky <noreply@yourdomain.com>"

# Optional — WhatsApp Cloud API (Meta) for seller alerts on new orders/inquiries
# Create app at https://developers.facebook.com → WhatsApp → API Setup
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
